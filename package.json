{
  "name": "n8n-nodes-preview",
  "version": "0.1.1",
  "description": "N8N community node — Preview Node for inline image/video/JSON previews on the canvas (Weavy AI / ComfyUI style)",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "preview",
    "image",
    "video",
    "canvas"
  ],
  "license": "MIT",
  "author": {
    "name": "Ariel Tolome",
    "url": "https://github.com/ArielleTolome"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ArielleTolome/n8n-nodes-preview.git"
  },
  "homepage": "https://github.com/ArielleTolome/n8n-nodes-preview",
  "bugs": {
    "url": "https://github.com/ArielleTolome/n8n-nodes-preview/issues"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/nodes/PreviewNode/*.svg dist/nodes/PreviewNode/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [],
    "nodes": [
      "dist/nodes/PreviewNode/PreviewNode.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "n8n-workflow": "^2.13.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
}
